{
  "enabled": true,
  "provider": "voxcpm-bridge",
  "playback": {
    "mode": "none",
    "command": ["afplay", "$AUDIO_PATH"]
  },
  "profilePath": "./plugins/does-not-exist.json",
  "filters": {
    "minLength": 12,
    "maxLength": 4000,
    "skipCodeBlocks": true,
    "blockedMarkers": [
      "## Shared Contract",
      "## Coordination Message",
      "## Coordination Trace",
      "validation-failure",
      "tool_use"
    ]
  },
  "voxcpmBridge": {
    "mode": "cli",
    "command": ["python3", "./plugins/voxcpm_bridge_stub.py"],
    "timeoutMs": 30000
  }
}
