{
  "mode": "summary",
  "enabled": true,
  "provider": "voxcpm-bridge",
  "playback": {
    "mode": "command",
    "command": [
      "afplay",
      "$AUDIO_PATH"
    ]
  },
  "profilePath": "./plugins/voice-output.profile.fer-miralles.json",
  "filters": {
    "minLength": 12,
    "maxLength": 4000,
    "skipCodeBlocks": true,
    "spokenSummaryMarker": "## Resumen hablado",
    "blockedMarkers": [
      "## Shared Contract",
      "## Coordination Message",
      "## Coordination Trace",
      "validation-failure",
      "tool_use"
    ]
  },
  "voxcpmBridge": {
    "mode": "cli",
    "command": [
      "/Users/arian/Documents/Dev/github_projects/VoxCPM/.venv/bin/python",
      "./plugins/voxcpm_bridge.py"
    ],
    "timeoutMs": 300000
  }
}
